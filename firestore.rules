rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthed() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthed() && request.auth.token.admin == true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.uid == userId;
      allow update, delete: if false;

      match /ledger/{entryId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }

      match /rounds/{roundId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }

      match /slotRounds/{roundId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }

      match /slotStates/{stateId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }

      match /slotAudits/{auditId} {
        allow read: if isAdmin();
        allow write: if false;
      }

      match /manual_uploads/{requestId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      match /wallet/{walletId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }
    }

    match /manualReviews/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /debitLocks/{docId} {
      allow read, write: if false;
    }

    match /payoutLocks/{docId} {
      allow read, write: if false;
    }

    match /depositLocks/{docId} {
      allow read, write: if false;
    }

    match /withdrawLocks/{docId} {
      allow read, write: if false;
    }

    // depositRequests: users can create their own, admin reads/processes via Admin SDK
    match /depositRequests/{requestId} {
      allow read: if isAdmin();
      allow create: if isAuthed() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // withdrawalRequests: users can create their own, admin reads/processes via Admin SDK
    match /withdrawalRequests/{requestId} {
      allow read: if isAdmin();
      allow create: if isAuthed() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // phoneIndex: written only by Admin SDK (callable functions), never by clients
    match /phoneIndex/{phoneKey} {
      allow read, write: if false;
    }

    // sentryFlags: admin read only, written by Admin SDK
    match /sentryFlags/{uid} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // system_logs: admin read only, written by Admin SDK
    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
